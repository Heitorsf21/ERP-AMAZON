  quantityInventory         Int       @default(0)
  quantityTotal             Int       @default(0)
  originalReimbursementId   String?
  originalReimbursementType String?
  produtoId                 String?
  payloadJson               Json
  criadoEm                  DateTime  @default(now())
  atualizadoEm              DateTime  @updatedAt

