model AdsOptimizationRun {
  id                 String    @id @default(cuid())
  empresaId          String?
  profileId          String
  status             String    @default("RUNNING")
  iniciadoPorId      String?
  iniciadoPorEmail   String?
  iniciadoEm         DateTime  @default(now())
  finalizadoEm       DateTime?
  totalEntidades     Int       @default(0)
  totalRecomendacoes Int       @default(0)
  erro               String?
  payloadJson        String?

  recomendacoes AdsOptimizationRecommendation[]

  @@index([profileId])
  @@index([status])
  @@index([iniciadoEm])
}

model AdsOptimizationRecommendation {
  id                  String   @id @default(cuid())
  empresaId           String?
  runId               String?
  profileId           String
  status              String   @default("PROPOSED")
  entityType          String
  entityId            String
  campaignId          String
  campaignName        String?
  portfolioId         String?
  portfolioName       String?
  adGroupId           String?
  adGroupName         String?
  keywordId           String?
  targetId            String?
  searchTerm          String?
  sku                 String?
  asin                String?
  actionType          String
  severity            String
  ruleId              String
  motivo              String
  risco               String?
  confianca           Int      @default(0)
  currentBidCentavos  Int?
  proposedBidCentavos Int?
  beforeState         String?
  proposedState       String?
  metrics7dJson       String
  metrics30dJson      String
  metricsLifetimeJson String
  evidenceJson        String
  amazonPayloadJson   String?
  aprovadoPorId       String?
  aprovadoPorEmail    String?
  aprovadoEm          DateTime?
  rejeitadoPorId      String?
  rejeitadoPorEmail   String?
  rejeitadoEm         DateTime?
  executadoEm         DateTime?
  staleReason         String?
  errorMessage        String?
  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt

  run AdsOptimizationRun? @relation(fields: [runId], references: [id], onDelete: SetNull)
  execucoes AdsOptimizationExecutionLog[]

  @@index([profileId, status])
  @@index([actionType])
  @@index([severity])
  @@index([campaignId])
  @@index([entityType, entityId])
  @@index([criadoEm])
}

model AdsOptimizationExecutionLog {
  id                 String   @id @default(cuid())
  empresaId          String?
  recommendationId   String
  status             String
  requestJson        String?
  responseJson       String?
  errorMessage       String?
  executadoPorId     String?
  executadoPorEmail  String?
  executadoEm        DateTime @default(now())

  recommendation AdsOptimizationRecommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)

  @@index([recommendationId])
  @@index([status])
  @@index([executadoEm])
}
