// ERP AMAZON — schema Prisma (PostgreSQL)
//
// Convenções:
// - Dinheiro em centavos (Int). Nunca Float.
// - Datas em UTC; lógica de fuso (America/Sao_Paulo) é aplicada na camada de serviço.
// - Enums representados como String + constantes de domínio (mais flexível que enum nativo).
// - Cada modelo tem createdAt/updatedAt para auditoria básica.
// - Campos JSON usam tipo Json (mapeia para jsonb no Postgres).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── Multiempresa (multi-tenant) ─────────────────────────────────────────────
// Fundação do isolamento por empresa. `empresaId` será propagado aos modelos
// "owned" em blocos posteriores; aqui ficam os modelos base + o vínculo do
// Usuario. O SUPERADMIN da plataforma vive em PlataformaUsuario (fora do escopo
// tenant) para não poluir queries tenant-scoped nem o RLS.

model Empresa {
  id        String   @id @default(cuid())
  nome      String
  // Identificador curto usado no login/seletor de empresa (ex: "mundofs").
  slug      String   @unique
  ativa     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  usuarios       Usuario[]
  amazonAccounts AmazonAccount[]

  @@index([ativa])
}

model AmazonAccount {
  id            String   @id @default(cuid())
  empresaId     String
  nome          String
  marketplaceId String?
  sellerId      String?
  endpoint      String?
  // Credenciais OAuth por seller (F02). refresh_token cifrado AES-256-GCM (crypto.ts,
  // formato enc:v1:). access token cacheado é opcional (refresh sob demanda).
  refreshTokenEnc String?
  accessTokenEnc  String?
  tokenExpiresAt  DateTime?
  lwaScopes       String?
  conectadoEm     DateTime?
  ativa         Boolean  @default(true)
  // PENDENTE | ATIVA | ERRO — gate do worker (só itera contas ATIVA com credenciais).
  status        String   @default("PENDENTE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  empresa Empresa @relation(fields: [empresaId], references: [id], onDelete: Cascade)

  @@index([empresaId])
  @@index([ativa])
}

model PlataformaUsuario {
  id             String    @id @default(cuid())
  email          String    @unique
  senhaHash      String
  nome           String
  ativo          Boolean   @default(true)
  ultimoAcesso   DateTime?
  sessionVersion Int       @default(0)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([ativo])
}

// ── Autenticação ────────────────────────────────────────────────────────────

model Usuario {
  id               String    @id @default(cuid())
  email            String
  senhaHash        String
  nome             String
  // ADMIN | OPERADOR | FINANCEIRO | LEITURA
  role             String    @default("ADMIN")
  ativo            Boolean   @default(true)
  avatarUrl        String?
  ultimoAcesso     DateTime?
  twoFactorEnabled Boolean   @default(false)
  twoFactorMethod  String?
  // Incrementado a cada troca de senha ou "encerrar todas as sessoes".
  sessionVersion   Int       @default(0)
  empresaId        String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  empresa           Empresa                 @relation(fields: [empresaId], references: [id])
  tokensRecuperacao TokenRecuperacaoSenha[]
  codigos2fa        CodigoVerificacao2FA[]
  convites          ConviteUsuario[]
  auditLogs         AuditLog[]
  tarefas           Tarefa[]

  @@unique([empresaId, email])
  @@index([email])
  @@index([ativo])
  @@index([empresaId])
}

model TokenRecuperacaoSenha {
  id        String    @id @default(cuid())
  usuarioId String
  tokenHash String    @unique
  expiresAt DateTime
  usadoEm   DateTime?
  createdAt DateTime  @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([expiresAt])
}

model ConviteUsuario {
  id        String    @id @default(cuid())
  usuarioId String
  tokenHash String    @unique
  expiresAt DateTime
  usadoEm   DateTime?
  createdAt DateTime  @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([expiresAt])
}

model AuditPlataforma {
  id                  String   @id @default(cuid())
  plataformaUsuarioId String?
  acao                String
  empresaIdAlvo       String?
  metadata            String?  // JSON serializado (String em AMBOS os schemas)
  ip                  String?
  createdAt           DateTime @default(now())

  @@index([plataformaUsuarioId])
  @@index([empresaIdAlvo])
  @@index([createdAt])
}

model LoginThrottle {
  id        String   @id @default(cuid())
  chave     String   @unique
  count     Int      @default(0)
  resetAt   DateTime
  updatedAt DateTime @updatedAt

  @@index([resetAt])
}

model CodigoVerificacao2FA {
  id          String    @id @default(cuid())
  usuarioId   String
  codigoHash  String
  challengeId String    @unique
  expiresAt   DateTime
  usadoEm     DateTime?
  tentativas  Int       @default(0)
  createdAt   DateTime  @default(now())

  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([challengeId])
  @@index([expiresAt])
}

model Categoria {
  id        String   @id @default(cuid())
  empresaId String?
  nome      String
  // RECEITA | DESPESA | AMBAS
  tipo      String
  cor       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  movimentacoes Movimentacao[]
  contas        ContaPagar[]
  contasFixas   ContaFixa[]

  @@unique([empresaId, nome])
}

model Fornecedor {
  id          String   @id @default(cuid())
  empresaId   String?
  nome        String
  documento   String?
  contato     String?
  observacoes String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  contas      ContaPagar[]
  pedidos     PedidoCompra[]
  contasFixas ContaFixa[]

  @@unique([empresaId, nome])
}

model Movimentacao {
  id              String    @id @default(cuid())
  empresaId       String?
  // ENTRADA | SAIDA
  tipo            String
  valor           Int
  dataCompetencia DateTime
  dataCaixa       DateTime
  categoriaId     String
  descricao       String
  // MANUAL | CONTA_PAGA | IMPORTACAO | AJUSTE
  origem          String
  referenciaId    String?
  motivoAjuste    String?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  categoria    Categoria     @relation(fields: [categoriaId], references: [id], onDelete: Restrict)
  contaPaga    ContaPagar?   @relation("ContaPagaMovimentacao")
  contaReceber ContaReceber? @relation("ContaReceberMovimentacao")

  @@index([dataCaixa])
  @@index([tipo])
  @@index([categoriaId])
  @@index([origem])
}

model ContaPagar {
  id             String    @id @default(cuid())
  empresaId      String?
  fornecedorId   String
  categoriaId    String
  descricao      String
  valor          Int
  vencimento     DateTime
  // ABERTA | VENCIDA | PAGA | CANCELADA
  status         String    @default("ABERTA")
  // NENHUMA | MENSAL
  recorrencia    String    @default("NENHUMA")
  contaPaiId     String?
  pagoEm         DateTime?
  movimentacaoId String?   @unique
  observacoes    String?
  // Ocorrência gerada a partir de uma ContaFixa — idempotência via @@unique([contaFixaId, competencia]).
  contaFixaId    String?
  competencia    String? // "YYYY-MM" — preenchido apenas em ocorrências de conta fixa
  deletedAt      DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  fornecedor Fornecedor @relation(fields: [fornecedorId], references: [id], onDelete: Restrict)
  categoria  Categoria  @relation(fields: [categoriaId], references: [id], onDelete: Restrict)
  nfAnexo    String?
  nfNome     String?

  contaPai         ContaPagar?       @relation("Recorrencia", fields: [contaPaiId], references: [id], onDelete: SetNull)
  filhas           ContaPagar[]      @relation("Recorrencia")
  movimentacao     Movimentacao?     @relation("ContaPagaMovimentacao", fields: [movimentacaoId], references: [id], onDelete: SetNull)
  dossieFinanceiro DossieFinanceiro?
  pedidoCompra     PedidoCompra?     @relation("PedidoContaPagar")
  contaFixa        ContaFixa?        @relation("ContaFixaOcorrencias", fields: [contaFixaId], references: [id], onDelete: SetNull)

  @@unique([contaFixaId, competencia])
  @@index([status])
  @@index([vencimento])
  @@index([fornecedorId])
  @@index([contaFixaId])
}

// ── Agenda: contas fixas (recorrentes/não recorrentes) ──────────────────────
model ContaFixa {
  id               String    @id @default(cuid())
  empresaId        String?
  descricao        String
  valor            Int // centavos
  diaVencimento    Int // 1..31 — clampa ao último dia quando o mês não tem o dia
  recorrente       Boolean   @default(true)
  // "YYYY-MM" — competência da ocorrência única (só quando recorrente = false)
  competenciaUnica String?
  ativa            Boolean   @default(true)
  categoriaId      String?
  fornecedorId     String?
  observacoes      String?
  deletedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  categoria   Categoria?   @relation(fields: [categoriaId], references: [id], onDelete: SetNull)
  fornecedor  Fornecedor?  @relation(fields: [fornecedorId], references: [id], onDelete: SetNull)
  ocorrencias ContaPagar[] @relation("ContaFixaOcorrencias")

  @@index([ativa])
  @@index([diaVencimento])
}

model DossieFinanceiro {
  id                  String    @id @default(cuid())
  empresaId           String?
  fornecedorNome      String?
  fornecedorDocumento String?
  descricao           String?
  valor               Int?
  vencimento          DateTime?
  numeroDocumento     String?
  status              String    @default("PENDENTE")
  contaPagarId        String?   @unique
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  contaPagar ContaPagar?           @relation(fields: [contaPagarId], references: [id], onDelete: SetNull)
  documentos DocumentoFinanceiro[]

  @@index([status])
  @@index([fornecedorDocumento])
  @@index([vencimento])
}

model DocumentoFinanceiro {
  id                  String    @id @default(cuid())
  empresaId           String?
  dossieId            String
  tipo                String
  nomeArquivo         String
  caminhoArquivo      String
  mimeType            String
  sha256              String
  textoExtraido       String?
  fornecedorNome      String?
  fornecedorDocumento String?
  descricao           String?
  valor               Int?
  vencimento          DateTime?
  numeroDocumento     String?
  chaveAcesso         String?
  linhaDigitavel      String?
  dataEmissao         DateTime?
  protegidoPorSenha   Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  dossie DossieFinanceiro @relation(fields: [dossieId], references: [id], onDelete: Cascade)

  @@unique([empresaId, sha256])
  @@index([dossieId])
  @@index([tipo])
  @@index([fornecedorDocumento])
  @@index([vencimento])
}

model ContaReceber {
  id              String    @id @default(cuid())
  empresaId       String?
  descricao       String
  valor           Int
  dataPrevisao    DateTime?
  dataRecebimento DateTime?
  // PENDENTE | RECEBIDA | CANCELADA
  status          String    @default("PENDENTE")
  // AMAZON | MANUAL
  origem          String    @default("AMAZON")
  liquidacaoId    String?
  totalPedidos    Int       @default(0)
  movimentacaoId  String?   @unique
  observacoes     String?
  deletedAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  movimentacao Movimentacao? @relation("ContaReceberMovimentacao", fields: [movimentacaoId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([dataPrevisao])
  @@index([liquidacaoId])
}

// ── Estoque ─────────────────────────────────────────────────────────────────

model Produto {
  id                          String    @id @default(cuid())
  empresaId                   String?
  sku                         String
  asin                        String?
  nome                        String
  descricao                   String?
  custoUnitario               Int?
  precoVenda                  Int?
  amazonEstoqueDisponivel     Int?
  amazonEstoqueReservado      Int?
  amazonEstoqueInbound        Int?
  amazonEstoqueTotal          Int?
  amazonUltimaSyncEm          DateTime?
  estoqueAtual                Int       @default(0)
  estoqueMinimo               Int       @default(0)
  unidade                     String    @default("un")
  ativo                       Boolean   @default(true)
  solicitarReviewsAtivo       Boolean   @default(true)
  imagemUrl                   String?
  observacoes                 String?
  // Catálogo Amazon
  amazonImagemUrl             String?
  amazonTituloOficial         String?
  amazonCategoria             String?
  amazonCatalogSyncEm         DateTime?
  // Buybox snapshot atual
  buyboxGanho                 Boolean?
  buyboxPreco                 Int?
  buyboxConcorrentes          Int?
  buyboxUltimaSyncEm          DateTime?
  // Preco do listing (our_price) sincronizado via /listings/2021-08-01.
  // Usado como fallback em pedidos Pending que ainda nao tem ItemPrice na SP-API.
  amazonPrecoListagemCentavos Int?
  amazonPrecoListagemSyncEm   DateTime?
  // Slug da categoria Amazon para o fee-estimator. Ver schema.prisma.
  amazonCategoriaFee          String?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  movimentacoes           MovimentacaoEstoque[]
  itensPedido             ItemPedidoCompra[]
  metricas                ProdutoMetricaGestorSeller[]
  adsGastosManuais        AdsGastoManual[]
  reembolsosAmazon        AmazonReembolso[]
  buyboxSnapshots         BuyBoxSnapshot[]
  inventorySnapshots      InventorySnapshot[]
  reimbursementsFba       AmazonReimbursement[]
  returnsAmazon           AmazonReturn[]
  skuTrafficDaily         AmazonSkuTrafficDaily[]
  adsMetricasDiarias      AmazonAdsMetricaDiaria[]
  adsMetricasHorarias     AmazonAdsMetricaHoraria[]
  variacoesPai            ProdutoVariacao[]               @relation("ProdutoVariacaoPai")
  variacaoComoFilho       ProdutoVariacao?                @relation("ProdutoVariacaoFilho")
  custoHistorico          ProdutoCustoHistorico[]
  feeEstimate             AmazonFeeEstimate?
  whatsappEstoqueExcluido WhatsAppEstoqueProdutoExcluido?

  @@unique([empresaId, sku])
  @@index([sku])
  @@index([asin])
  @@index([ativo])
  @@index([amazonUltimaSyncEm])
  @@index([estoqueAtual])
}

// Estimativa de taxas Amazon (comissão + FBA). Ver doc em schema.prisma.
model AmazonFeeEstimate {
  produtoId              String   @id
  empresaId              String?
  comissaoBps            Int
  fbaCentavos            Int
  ticketAvaliadoCentavos Int
  origem                 String
  ruleVersion            String?
  atualizadoEm           DateTime @updatedAt

  produto Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@index([atualizadoEm])
}

// Vigências de custo unitário ao longo do tempo. Ver doc em schema.prisma.
model ProdutoCustoHistorico {
  id             String    @id @default(cuid())
  empresaId      String?
  produtoId      String
  custoCentavos  Int
  vigenciaInicio DateTime
  vigenciaFim    DateTime?
  origem         String
  observacao     String?
  criadoEm       DateTime  @default(now())

  produto Produto @relation(fields: [produtoId], references: [id], onDelete: Cascade)

  @@unique([produtoId, vigenciaInicio])
  @@index([produtoId, vigenciaInicio])
  @@index([vigenciaInicio])
}

model VendaAmazon {
  id                         String    @id @default(cuid())
  empresaId                  String?
  amazonOrderId              String
  orderItemId                String?
  sku                        String
  asin                       String?
  titulo                     String?
  quantidade                 Int
  precoUnitarioCentavos      Int
  valorBrutoCentavos         Int?
  taxasCentavos              Int       @default(0)
  fretesCentavos             Int       @default(0)
  liquidoMarketplaceCentavos Int?
  impostoSimplesCentavos     Int       @default(0)
  custoUnitarioCentavos      Int?
  liquidacaoId               String?
  marketplace                String?
  fulfillmentChannel         String?
  statusPedido               String    @default("UNKNOWN")
  statusFinanceiro           String    @default("PENDENTE")
  // Origem do valorBrutoCentavos: "sp-api" (ItemPrice real), "listing"
  // (fallback do Produto.amazonPrecoListagemCentavos enquanto Pending) ou
  // null (legado). Apenas "sp-api" entra em DRE/Contas a Receber.
  precoOrigem                String?
  dataVenda                  DateTime
  ultimaSyncEm               DateTime?
  criadoEm                   DateTime  @default(now())
  atualizadoEm               DateTime  @updatedAt

  custosEventuais VendaCustoEventual[]

  @@unique([amazonOrderId, sku])
  @@index([orderItemId])
  @@index([dataVenda])
  @@index([sku])
  @@index([liquidacaoId])
  @@index([statusPedido])
  @@index([statusFinanceiro])
  @@index([ultimaSyncEm])
  @@index([dataVenda, statusFinanceiro])
  @@index([precoOrigem])
}

// Custos eventuais ad-hoc por linha de venda (frete devolução, embalagem,
// ajustes manuais). Vivem fora de VendaAmazon para preservar a regra
// "campos sagrados" (taxasCentavos/fretesCentavos/liquidoMarketplaceCentavos
// são gravados apenas pela Finance API).
model VendaCustoEventual {
  id            String   @id @default(cuid())
  empresaId     String?
  vendaAmazonId String
  descricao     String
  valorCentavos Int
  criadoEm      DateTime @default(now())
  criadoPor     String?

  venda VendaAmazon @relation(fields: [vendaAmazonId], references: [id], onDelete: Cascade)

  @@index([vendaAmazonId])
}

model AmazonOrderRaw {
  id                 String    @id @default(cuid())
  empresaId          String?
  amazonOrderId      String    @unique
  statusPedido       String    @default("UNKNOWN")
  createdTime        DateTime?
  lastUpdatedTime    DateTime?
  marketplaceId      String?
  fulfillmentChannel String?
  payloadJson        Json
  itensProcessados   Boolean   @default(false)
  ultimaSyncEm       DateTime?
  criadoEm           DateTime  @default(now())
  atualizadoEm       DateTime  @updatedAt

  @@index([statusPedido])
  @@index([createdTime])
  @@index([lastUpdatedTime])
  @@index([itensProcessados])
  @@index([ultimaSyncEm])
}

model ProdutoVariacao {
  id             String   @id @default(cuid())
  empresaId      String?
  produtoPaiId   String
  produtoFilhoId String?  @unique
  skuPai         String
  skuFilho       String?
  nome           String?
  tipo           String?
  atributosJson  Json?
  criadoEm       DateTime @default(now())
  atualizadoEm   DateTime @updatedAt

  produtoPai   Produto  @relation("ProdutoVariacaoPai", fields: [produtoPaiId], references: [id], onDelete: Cascade)
  produtoFilho Produto? @relation("ProdutoVariacaoFilho", fields: [produtoFilhoId], references: [id], onDelete: SetNull)

  @@unique([produtoPaiId, skuFilho])
  @@index([produtoPaiId])
  @@index([skuPai])
  @@index([skuFilho])
}

model AmazonReembolso {
  id                        String   @id @default(cuid())
  empresaId                 String?
  amazonOrderId             String
  orderItemId               String?
  sku                       String
  asin                      String?
  titulo                    String?
  quantidade                Int      @default(0)
  valorReembolsadoCentavos  Int
  taxasReembolsadasCentavos Int      @default(0)
  dataReembolso             DateTime
  liquidacaoId              String?
  marketplace               String?
  referenciaExterna         String   @unique
  statusFinanceiro          String?
  motivoCategoria           String?
  produtoId                 String?
  criadoEm                  DateTime @default(now())
  atualizadoEm              DateTime @updatedAt

  produto Produto? @relation(fields: [produtoId], references: [id], onDelete: SetNull)

  @@index([amazonOrderId])
  @@index([orderItemId])
  @@index([sku])
  @@index([dataReembolso])
  @@index([liquidacaoId])
  @@index([produtoId])
  @@index([motivoCategoria])
}

model AdsGastoManual {
  id            String   @id @default(cuid())
  empresaId     String?
  periodoInicio DateTime
  periodoFim    DateTime
  produtoId     String?
  valorCentavos Int
  criadoEm      DateTime @default(now())

  produto Produto? @relation(fields: [produtoId], references: [id], onDelete: SetNull)

  @@index([periodoInicio, periodoFim])
  @@index([produtoId])
}

model MovimentacaoEstoque {
  id               String   @id @default(cuid())
  empresaId        String?
  produtoId        String
  // ENTRADA | SAIDA
  tipo             String
  quantidade       Int
  custoUnitario    Int?
  // MANUAL | IMPORTACAO | AJUSTE | COMPRA | VENDA
  origem           String
  referenciaId     String?
  observacoes      String?
  dataMovimentacao DateTime
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  produto Produto @relation(fields: [produtoId], references: [id], onDelete: Restrict)

  @@index([produtoId])
  @@index([dataMovimentacao])
  @@index([tipo])
  @@index([origem])
}

// ── Compras & Reposição ─────────────────────────────────────────────────────

model PedidoCompra {
  id              String             @id @default(cuid())
  empresaId       String?
  numero          String?
  fornecedorId    String?
  fornecedor      Fornecedor?        @relation(fields: [fornecedorId], references: [id], onDelete: Restrict)
  // RASCUNHO | CONFIRMADO | RECEBIDO | CANCELADO
  status          String             @default("RASCUNHO")
  dataEmissao     DateTime           @default(now())
  dataPrevisao    DateTime?
  dataRecebimento DateTime?
  totalCentavos   Int                @default(0)
  observacoes     String?
  contaPagarId    String?            @unique
  contaPagar      ContaPagar?        @relation("PedidoContaPagar", fields: [contaPagarId], references: [id], onDelete: SetNull)
  itens           ItemPedidoCompra[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status])
  @@index([dataEmissao])
  @@index([fornecedorId])
}

model ItemPedidoCompra {
  id            String       @id @default(cuid())
  empresaId     String?
  pedidoId      String
  pedido        PedidoCompra @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  produtoId     String
  produto       Produto      @relation(fields: [produtoId], references: [id], onDelete: Restrict)
  quantidade    Int
  custoUnitario Int
  subtotal      Int
  createdAt     DateTime     @default(now())

  @@index([pedidoId])
  @@index([produtoId])
}

// ── Amazon Sync ──────────────────────────────────────────────────────────────

model AmazonSyncLog {
  id        String   @id @default(cuid())
  empresaId String?
  tipo      String
  // PROCESSANDO | SUCESSO | ERRO
  status    String
  mensagem  String?
  detalhes  Json?
  registros Int      @default(0)
  createdAt DateTime @default(now())

  @@index([createdAt])
  @@index([tipo])
  @@index([status])
}

model AmazonSyncJob {
  id          String    @id @default(cuid())
  empresaId   String?
  tipo        String
  // QUEUED | RUNNING | SUCCESS | FAILED | CANCELLED
  status      String    @default("QUEUED")
  priority    Int       @default(0)
  payload     Json?
