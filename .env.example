# ────────────────────────────────────────────────────────────────────
# ERP Amazon — variáveis de ambiente
# ────────────────────────────────────────────────────────────────────

# Banco de dados — PRODUÇÃO usa PostgreSQL na VPS Hostinger.
# Exemplo VPS:  postgresql://erp_amazon:senha_forte@127.0.0.1:5432/erp_amazon?schema=public
# Para migrar dados antigos do SQLite, mantenha o arquivo dev.db e rode:
#   SQLITE_URL="file:./prisma/dev.db" npm run migrate:sqlite-to-postgres
DATABASE_URL="postgresql://erp_amazon:trocar@127.0.0.1:5432/erp_amazon?schema=public"

# ─── Isolamento multi-tenant (SaaS multi-seller) ───────────────────
# Controla a extensão do Prisma que injeta `empresaId` em todas as queries
# (src/lib/db.ts). Valores: "off" (default — single-tenant, NO-OP) | "enforce".
# OBRIGATÓRIO definir "enforce" ANTES de cadastrar a 2ª empresa: sem isso as
# queries cruzam tenants e vazam dados/PII. O guard de boot (instrumentation.ts /
# worker) ABORTA o processo se houver >1 empresa e esta flag não estiver em
# "enforce". Rollout em produção é GATED: faça backup + valide em staging antes.
TENANT_ISOLATION="off"
# Fallback opcional p/ caminhos sem contexto de tenant (single-tenant interino).
# SEGURO apenas com UMA empresa. Deixe vazio quando TENANT_ISOLATION=enforce com 2+.
TENANT_FALLBACK_EMPRESA=""

# Log: "debug" | "info" | "warn" | "error"
LOG_LEVEL="info"

# Fuso horário padrão (usado em projeções e recorrências)
TZ="America/Sao_Paulo"

# Chave HMAC para assinatura de sessão (mínimo 32 caracteres).
# Gerar com:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=""

# Chave HMAC da sessão do SUPERADMIN (plataforma) — SEPARADA de SESSION_SECRET.
# Sem ela, o login em /plataforma lança 500. Mínimo 32 caracteres.
# Gerar com:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
PLATAFORMA_SESSION_SECRET=""

# Forçar cookie `Secure` (HTTPS-only) mesmo fora de NODE_ENV=production —
# útil para staging atrás de TLS proxy. "true" / "false". Default: segue NODE_ENV.
COOKIE_SECURE=""

# Promover CSP de Report-Only para enforce ("true"). Default: Report-Only.
# Antes de ativar, confirmar 0 violações em DevTools por 1-2 semanas. Ver docs/csp.md.
CSP_ENFORCE=""

# Chave AES-256-GCM para criptografar credenciais sensíveis (LWA secret/refresh, OAuth tokens, etc.).
# 32 bytes em hex. Gerar com:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANTE: nunca rodar a app sem essa chave em produção. Trocar a chave invalida todos os valores criptografados.
CONFIG_ENCRYPTION_KEY=""

# URL exclusiva para `prisma migrate deploy` quando aplicar least-privilege
# do Postgres (docs/postgres-roles.md). Opcional — se vazio, usa DATABASE_URL.
# MIGRATION_DATABASE_URL="postgresql://erp_amazon_owner:..."

# Usuário inicial criado pelo seed (apenas se ainda não existir no banco).
AUTH_SEED_EMAIL=""
AUTH_SEED_SENHA=""
AUTH_SEED_NOME=""

# ─── Amazon SP-API privada (Brasil) ─────────────────────────────────
# Preencha esses valores na tela /amazon ou no banco de configurações.
# Nunca commitar credenciais reais.
AMAZON_LWA_CLIENT_ID=""
AMAZON_LWA_CLIENT_SECRET=""
AMAZON_LWA_REFRESH_TOKEN=""
AMAZON_MARKETPLACE_ID="A2Q3Y263D00KWC"
AMAZON_SP_API_ENDPOINT="https://sellingpartnerapi-na.amazon.com"

# ─── OAuth multi-seller (F02 — consentimento por seller) ────────────
# application_id do app no Developer Console (Seller Central). Usado na URL de
# consentimento — DIFERENTE do AMAZON_LWA_CLIENT_ID (este é a credencial LWA do
# mesmo app, usada na troca code->token).
AMAZON_APP_ID=""
# Credenciais LWA do app OAuth novo. Use quando ele for diferente do app legado
# configurado em AMAZON_LWA_*; isso preserva a integracao atual durante testes.
AMAZON_OAUTH_LWA_CLIENT_ID=""
AMAZON_OAUTH_LWA_CLIENT_SECRET=""
AMAZON_SELLERCENTRAL_BASE="https://sellercentral.amazon.com.br"
# "true" enquanto o app for DRAFT (adiciona version=beta no consent). "false"
# quando publicado no Developer Console.
AMAZON_OAUTH_DRAFT="true"
# redirect_uri usa APP_URL + /api/amazon/oauth/callback (configure APP_URL abaixo).

# ─── Amazon Ads API / OAuth ────────────────────────────────────────────────
# App Ads aprovado com scope advertising::campaign_management. Se o app OAuth
# Ads for diferente da config manual salva em /amazon, use AMAZON_ADS_OAUTH_*.
AMAZON_ADS_OAUTH_CLIENT_ID=""
AMAZON_ADS_OAUTH_CLIENT_SECRET=""
AMAZON_ADS_LWA_AUTHORIZE_URL="https://www.amazon.com/ap/oa"
AMAZON_ADS_ENDPOINT="https://advertising-api.amazon.com"
# redirect_uri usa APP_URL + /api/amazon/ads/oauth/callback.

# ─── Worker Amazon na VPS ───────────────────────────────────────────
AMAZON_WORKER_ID="amazon-worker"
AMAZON_WORKER_BATCH_SIZE="10"
AMAZON_WORKER_INTERVAL_MS="30000"

# Secret para chamadas externas em /api/amazon/cron-* (cron Linux ou cron Vercel).
# Gerar com:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=""

# Token interno para o watchdog/load-balancer obter detalhes em /api/health
# (worker.lastHeartbeatAt, queue, quota.cooldowns, lastSync) sem precisar de
# sessão ADMIN. O cliente envia o header `X-Internal-Health-Token: <token>`.
# Gerar com:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
INTERNAL_HEALTH_TOKEN=""

# ─── OpenAI (extração de PDFs) ──────────────────────────────────────
OPENAI_API_KEY=""

# ─── SMTP (recuperação de senha + 2FA por email) ────────────────────
# Em DEV, deixar vazio: emails caem no console (modo permissivo).
# Em PROD, configurar para emails reais saírem.
# Exemplo Gmail App Password:
#   SMTP_HOST="smtp.gmail.com"
#   SMTP_PORT="587"
#   SMTP_SECURE="false"
#   SMTP_USER="seu@gmail.com"
#   SMTP_PASS="senha_de_app_16_chars"
#   SMTP_FROM="\"ERP Mundo F&S\" <noreply@mundofs.cloud>"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="\"ERP Mundo F&S\" <noreply@mundofs.cloud>"

# DEV: logar o CORPO do email no console quando SMTP não está configurado.
# Default off (o corpo carrega link de reset/código 2FA/token de convite — não
# deve ir pra log). Defina "true" só para depuração local. Ignorado em produção.
EMAIL_DEV_LOG_BODY=""

# Base URL do app (usado em links de recuperação de senha)
APP_URL="http://localhost:3000"

# ─── Hardening de saída (SSRF) ──────────────────────────────────────
# Allowlist de host[:porta] para a URL do WAHA (resumo de estoque).
# Em PRODUÇÃO é obrigatória; sem allowlist o envio WAHA é bloqueado.
# Ajuste se o WAHA rodar em outro host. Separe múltiplos por vírgula.
WAHA_ALLOWED_HOSTS="127.0.0.1:3002,localhost:3002"

# ─── SQS (Amazon Notifications API — obrigatorio na Frente B) ──────
AMAZON_SQS_QUEUE_ARN=""
AMAZON_SQS_QUEUE_URL=""
AMAZON_SQS_REGION="us-east-1"
AMAZON_SQS_PRIMARY="true"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ─── Versão (deploy) ────────────────────────────────────────────────
# Setado pelo deploy automatizado (ex: GIT_SHA=$(git rev-parse --short HEAD))
GIT_SHA=""
