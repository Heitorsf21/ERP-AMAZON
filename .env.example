# ────────────────────────────────────────────────────────────────────
# ERP Amazon — variáveis de ambiente
# ────────────────────────────────────────────────────────────────────

# Banco de dados — PRODUÇÃO usa PostgreSQL na VPS Hostinger.
# Exemplo VPS:  postgresql://erp_amazon:senha_forte@127.0.0.1:5432/erp_amazon?schema=public
# Para migrar dados antigos do SQLite, mantenha o arquivo dev.db e rode:
#   SQLITE_URL="file:./prisma/dev.db" npm run migrate:sqlite-to-postgres
DATABASE_URL="postgresql://erp_amazon:trocar@127.0.0.1:5432/erp_amazon?schema=public"

# Log: "debug" | "info" | "warn" | "error"
LOG_LEVEL="info"

# Fuso horário padrão (usado em projeções e recorrências)
TZ="America/Sao_Paulo"

# Chave HMAC para assinatura de sessão (mínimo 32 caracteres).
# Gerar com:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=""

# Chave AES-256-GCM para criptografar credenciais sensíveis (LWA secret/refresh, OAuth tokens, etc.).
# 32 bytes em hex. Gerar com:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# IMPORTANTE: nunca rodar a app sem essa chave em produção. Trocar a chave invalida todos os valores criptografados.
CONFIG_ENCRYPTION_KEY=""

# Usuário inicial criado pelo seed (apenas se ainda não existir no banco).
AUTH_SEED_EMAIL=""
AUTH_SEED_SENHA=""
AUTH_SEED_NOME=""

# ─── Amazon SP-API privada (Brasil) ─────────────────────────────────
# Preencha esses valores na tela /amazon ou no banco de configurações.
# Nunca commitar credenciais reais.
AMAZON_LWA_CLIENT_ID=""
AMAZON_LWA_CLIENT_SECRET=""
AMAZON_LWA_REFRESH_TOKEN=""
AMAZON_MARKETPLACE_ID="A2Q3Y263D00KWC"
AMAZON_SP_API_ENDPOINT="https://sellingpartnerapi-na.amazon.com"

# ─── Worker Amazon na VPS ───────────────────────────────────────────
AMAZON_WORKER_ID="amazon-worker"
AMAZON_WORKER_BATCH_SIZE="10"
AMAZON_WORKER_INTERVAL_MS="30000"

# Secret para chamadas externas em /api/amazon/cron-* (cron Linux ou cron Vercel).
# Gerar com:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=""

# ─── OpenAI (extração de PDFs) ──────────────────────────────────────
OPENAI_API_KEY=""

# ─── SMTP (recuperação de senha + 2FA por email) ────────────────────
# Em DEV, deixar vazio: emails caem no console (modo permissivo).
# Em PROD, configurar para emails reais saírem.
# Exemplo Gmail App Password:
#   SMTP_HOST="smtp.gmail.com"
#   SMTP_PORT="587"
#   SMTP_SECURE="false"
#   SMTP_USER="seu@gmail.com"
#   SMTP_PASS="senha_de_app_16_chars"
#   SMTP_FROM="\"ERP Mundo F&S\" <noreply@mundofs.cloud>"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="\"ERP Mundo F&S\" <noreply@mundofs.cloud>"

# Base URL do app (usado em links de recuperação de senha)
APP_URL="http://localhost:3000"

# ─── SQS (Amazon Notifications API — opcional, push real-time) ──────
# Deixar vazio para manter só polling.
AMAZON_SQS_QUEUE_URL=""
AMAZON_SQS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# ─── Versão (deploy) ────────────────────────────────────────────────
# Setado pelo deploy automatizado (ex: GIT_SHA=$(git rev-parse --short HEAD))
GIT_SHA=""
